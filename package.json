{
  "name": "@phantompane/monorepo",
  "version": "6.0.0",
  "packageManager": "pnpm@10.8.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:shell": "turbo run test:shell --filter=@phantompane/cli-private",
    "test:shell:bash": "turbo run test:shell:bash --filter=@phantompane/cli-private",
    "test:shell:fish": "turbo run test:shell:fish --filter=@phantompane/cli-private",
    "test:shell:zsh": "turbo run test:shell:zsh --filter=@phantompane/cli-private",
    "lint": "turbo run lint //#lint:root",
    "fix": "turbo run fix //#fix:root",
    "lint:root": "oxfmt --check . '!packages/**'",
    "fix:root": "oxfmt --write . '!packages/**'",
    "typecheck": "turbo run typecheck",
    "ready": "turbo run fix typecheck test",
    "ready:check": "turbo run lint typecheck test",
    "phantom": "pnpm --filter @phantompane/cli-private run phantom",
    "compile": "turbo run compile --filter=@phantompane/cli-private"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "esbuild": "^0.27.3",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
