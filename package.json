{
  "name": "@phantompane/monorepo",
  "version": "6.2.0",
  "packageManager": "pnpm@10.8.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test --filter=!@phantompane/e2e",
    "test:e2e": "pnpm --filter @phantompane/e2e test",
    "test:shell": "pnpm --filter @phantompane/cli-private run test:shell",
    "test:shell:bash": "pnpm --filter @phantompane/cli-private run test:shell:bash",
    "test:shell:fish": "pnpm --filter @phantompane/cli-private run test:shell:fish",
    "test:shell:zsh": "pnpm --filter @phantompane/cli-private run test:shell:zsh",
    "lint": "turbo run lint //#lint:root",
    "fix": "turbo run fix //#fix:root",
    "lint:root": "oxfmt --check . '!packages/**'",
    "fix:root": "oxfmt --write . '!packages/**'",
    "typecheck": "turbo run typecheck",
    "ready": "turbo run fix typecheck test",
    "ready:check": "turbo run lint typecheck test",
    "phantom": "pnpm --filter @phantompane/cli-private run phantom",
    "compile": "turbo run compile --filter=@phantompane/cli-private"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript/native-preview": "7.0.0-dev.20260327.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsdown": "^0.21.5",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
