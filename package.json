{
  "name": "@phantompane/monorepo",
  "version": "6.0.0",
  "packageManager": "pnpm@10.8.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:shell": "pnpm --filter @phantompane/cli-private run test:shell",
    "test:shell:bash": "pnpm --filter @phantompane/cli-private run test:shell:bash",
    "test:shell:fish": "pnpm --filter @phantompane/cli-private run test:shell:fish",
    "test:shell:zsh": "pnpm --filter @phantompane/cli-private run test:shell:zsh",
    "lint": "oxfmt --check . && oxlint .",
    "fix": "oxfmt --write . && oxlint --fix .",
    "typecheck": "pnpm -r typecheck",
    "ready": "pnpm fix && pnpm typecheck && pnpm test",
    "ready:check": "pnpm lint && pnpm typecheck && pnpm test",
    "phantom": "pnpm --filter @phantompane/cli-private run phantom",
    "compile": "pnpm --filter @phantompane/cli-private run compile"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "esbuild": "^0.27.3",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
