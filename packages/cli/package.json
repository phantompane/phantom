{
  "name": "@phantompane/cli-private",
  "version": "6.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "phantom": "node --no-warnings --experimental-strip-types src/bin/phantom.ts",
    "build": "pnpm run build-app && tsdown && pnpm run copy-app",
    "build-app": "pnpm --dir ../app run build",
    "copy-app": "node --no-warnings --experimental-strip-types copy-app-assets.ts",
    "precompile": "rm -f output/*",
    "compile": "pnpm run build-app && pnpm run copy-app && node --no-warnings --experimental-strip-types build-executable.ts",
    "lint": "oxfmt --check . && oxlint .",
    "fix": "oxfmt --write . && oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "test:shell": "pnpm run test:shell:bash && pnpm run test:shell:zsh && pnpm run test:shell:fish",
    "test:shell:bash": "vitest run --root ../.. packages/cli/src/completions/phantom.bash.test.shell.ts",
    "test:shell:fish": "vitest run --root ../.. packages/cli/src/completions/phantom.fish.test.shell.ts",
    "test:shell:zsh": "vitest run --root ../.. packages/cli/src/completions/phantom.zsh.test.shell.ts",
    "test": "vitest run --root ../.. packages/cli/src --exclude packages/cli/src/**/*.test.shell.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@phantompane/core": "workspace:*",
    "@phantompane/git": "workspace:*",
    "@phantompane/github": "workspace:*",
    "@phantompane/mcp": "workspace:*",
    "@phantompane/preferences": "workspace:*",
    "@phantompane/process": "workspace:*",
    "@phantompane/utils": "workspace:*",
    "@phantompane/tmux": "workspace:*"
  }
}
