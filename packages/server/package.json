{
  "name": "@phantompane/server-private",
  "version": "6.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build && node --no-warnings --experimental-strip-types build-package.ts",
    "lint": "oxfmt --check . && oxlint .",
    "fix": "oxfmt --write . && oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/server/src"
  },
  "dependencies": {
    "next": "16.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
