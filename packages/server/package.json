{
  "name": "@phantompane/server-private",
  "version": "6.2.0",
  "private": true,
  "type": "module",
  "exports": {
    "./api": "./src/api.ts"
  },
  "scripts": {
    "dev": "node --watch --no-warnings --experimental-strip-types src/server/dev.ts",
    "build": "pnpm --filter @phantompane/gui build && tsdown && node --no-warnings --experimental-strip-types build-package.ts",
    "lint": "oxfmt --check . && oxlint .",
    "fix": "oxfmt --write . && oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/server/src"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@phantompane/gui": "workspace:*"
  }
}
